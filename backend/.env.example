# PostgreSQL database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=image_dedup

# API server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5170

# CORS - comma-separated allowed origins, or "*" to allow all
CORS_ORIGINS=*

# Authentication configuration
# Bootstrap admin credentials (used only when no users exist in the database)
BOOTSTRAP_LOGIN=admin
BOOTSTRAP_PASSWORD=changeme

# Session configuration
# SESSION_IDLE_HOURS: Session expires after this many hours of inactivity (default: 720 = 30 days)
# SESSION_ABSOLUTE_DAYS: Session expires after this many days regardless of activity (default: 90)
SESSION_IDLE_HOURS=720
SESSION_ABSOLUTE_DAYS=90

# OCR classifier configuration
# OCR_ENABLED: Enable OCR classifier integration (default: true)
# OCR_HOST: Host of OCR classifier service (default: localhost)
# OCR_PORT: Port of OCR classifier service (default: 8080)
# OCR_CHECK_INTERVAL: Health check interval in seconds (default: 10)
OCR_ENABLED=true
OCR_HOST=localhost
OCR_PORT=8080
OCR_CHECK_INTERVAL=10
