+				count++
+				sm.mu.Lock()
+				sm.progress = msg
+				sm.filesProcessed = count
+				sm.mu.Unlock()
+			}
+		}()
+
+		result := fastScanGalleryDirectory(sm.db, dirPath, progressChan, sm.scanWorkers)
+		stats = result
+
+		close(progressChan)
+
+		sm.mu.Lock()
+		sm.isScanning = false
+		sm.progress = "Fast scan complete"
+		sm.mu.Unlock()
+
+		if sm.OnScanComplete != nil {
+			sm.OnScanComplete()
+		}
+	}()
+
+	return stats
+}
